{
  "name": "@chatmux/web",
  "version": "0.0.1",
  "description": "Shared ChatMux React SPA for web, desktop, and mobile shells.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "desktop:build": "pnpm desktop:sidecar && tauri build",
    "desktop:build:macos": "scripts/build-desktop-macos.sh",
    "desktop:build:windows": "scripts/build-desktop-windows.sh",
    "desktop:dev": "pnpm desktop:sidecar && tauri dev",
    "desktop:sidecar": "src-tauri/scripts/build-gateway-sidecar.sh",
    "mobile:add:android": "cap add android",
    "mobile:add:ios": "cap add ios",
    "mobile:build:android-apk": "scripts/build-android-apk.sh",
    "mobile:build:android-internal": "scripts/build-android-internal.sh",
    "mobile:build:ios-testflight": "scripts/build-ios-testflight.sh",
    "mobile:sync": "pnpm build && cap sync",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/local-notifications": "^8.2.0",
    "@tauri-apps/api": "2.11.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
